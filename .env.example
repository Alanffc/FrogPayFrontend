# Configuración del Frontend - FrogPay Dashboard
# Copia este archivo como .env.local y actualiza los valores

# URL del Backend de Chris (HU-2.04)
# Cambiar a la URL real en producción
REACT_APP_BACKEND_URL=http://localhost:3000

# API Key del tenant: se obtiene al registrarse o iniciar sesión en FrogPay
# No debe quedar hardcodeada en el frontend
REACT_APP_API_KEY=

